        <skos:prefLabel xml:lang="en">Construction Process &amp; Management Document</skos:prefLabel>
        <ont:classificationPrompt xml:lang="en">Documents used to plan, monitor, and control construction activities and safety, such as project schedules, change orders, requests for information (RFIs), QA/QC reports, progress reports, and safety records.</ont:classificationPrompt>
