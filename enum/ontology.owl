        <ont:applicableContentCategories rdf:resource="https://dev.qaecy.com/enum#ContractualDocument"/>
        <ont:extractionPrompt xml:lang="en">The contract, identified by any means (id, name, title etc). If not explicitly mentioned, a descriptive term/title *must* be used instead.</ont:extractionPrompt>
    </owl:NamedIndividual>
    


