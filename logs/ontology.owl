<?xml version="1.0"?>
<rdf:RDF xmlns="https://dev.qaecy.com/logs#"
     xml:base="https://dev.qaecy.com/logs"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://dev.qaecy.com/logs#">
        <terms:creator>Christian Frausing</terms:creator>
        <terms:creator>Mads Holten Rasmussen</terms:creator>
        <terms:creator>Manos Argyris</terms:creator>
        <terms:description>This document describes log specific terms to be used with the Cue processors and the QAECY Ontology.</terms:description>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-26T10:06:33Z</terms:modified>
        <terms:title xml:lang="en">QAECY Logging Ontology</terms:title>
        <vann:preferredNamespacePrefix>qcy-l</vann:preferredNamespacePrefix>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/prov#generated -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#generated"/>
    


    <!-- http://www.w3.org/ns/prov#used -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#used"/>
    


    <!-- http://www.w3.org/ns/prov#wasAssociatedWith -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAssociatedWith"/>
    


    <!-- https://dev.qaecy.com/logs#consumed -->


    <owl:ObjectProperty rdf:about="https://dev.qaecy.com/logs#consumed">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:comment xml:lang="en">Sub-processes or external processes consumed by this process.</rdfs:comment>
        <rdfs:label xml:lang="en">consumed</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dev.qaecy.com/logs#executedBy -->


    <owl:ObjectProperty rdf:about="https://dev.qaecy.com/logs#executedBy">
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Service"/>
        <rdfs:range rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:label xml:lang="en">executed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dev.qaecy.com/logs#hasService -->


    <owl:ObjectProperty rdf:about="https://dev.qaecy.com/logs#hasService">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasAssociatedWith"/>
        <owl:inverseOf rdf:resource="https://dev.qaecy.com/logs#executedBy"/>
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="https://dev.qaecy.com/logs#Service"/>
        <rdfs:comment xml:lang="en">The service that executed this process.</rdfs:comment>
        <rdfs:label xml:lang="en">has service</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dev.qaecy.com/logs#hasSource -->


    <owl:ObjectProperty rdf:about="https://dev.qaecy.com/logs#hasSource">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="https://dev.qaecy.com/ont#FileLocation"/>
        <rdfs:comment xml:lang="en">Source file location used by this process.</rdfs:comment>
        <rdfs:label xml:lang="en">has source</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dev.qaecy.com/logs#hasTarget -->


    <owl:ObjectProperty rdf:about="https://dev.qaecy.com/logs#hasTarget">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#generated"/>
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="https://dev.qaecy.com/ont#FileLocation"/>
        <rdfs:comment xml:lang="en">Target file location generated by this process.</rdfs:comment>
        <rdfs:label xml:lang="en">has target</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/prov#endedAtTime -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#endedAtTime"/>
    


    <!-- http://www.w3.org/ns/prov#startedAtTime -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#startedAtTime"/>
    


    <!-- https://dev.qaecy.com/logs#consumedTokensIn -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#consumedTokensIn">
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#LLMRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Input tokens consumed by LLM request.</rdfs:comment>
        <rdfs:label xml:lang="en">tokens in</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dev.qaecy.com/logs#consumedTokensOut -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#consumedTokensOut">
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#LLMRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Output tokens consumed by LLM request.</rdfs:comment>
        <rdfs:label xml:lang="en">tokens out</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dev.qaecy.com/logs#duration -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#duration">
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Human-readable duration string (e.g., &apos;17.1 s&apos;).</rdfs:comment>
        <rdfs:label xml:lang="en">duration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dev.qaecy.com/logs#endTime -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#endTime">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#endedAtTime"/>
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Timestamp when the process ended.</rdfs:comment>
        <rdfs:label xml:lang="en">end time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dev.qaecy.com/logs#message -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#message">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A message such as an error or informational message.</rdfs:comment>
        <rdfs:label xml:lang="en">message</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dev.qaecy.com/logs#startTime -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#startTime">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#startedAtTime"/>
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Timestamp when the process started.</rdfs:comment>
        <rdfs:label xml:lang="en">start time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dev.qaecy.com/logs#success -->


    <owl:DatatypeProperty rdf:about="https://dev.qaecy.com/logs#success">
        <rdfs:domain rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Whether the process completed successfully.</rdfs:comment>
        <rdfs:label xml:lang="en">success</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/prov#Activity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity"/>
    


    <!-- http://www.w3.org/ns/prov#Agent -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Agent"/>
    


    <!-- https://dev.qaecy.com/logs#EmbeddingRequest -->


    <owl:Class rdf:about="https://dev.qaecy.com/logs#EmbeddingRequest">
        <rdfs:subClassOf rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:comment xml:lang="en">A process representing an embedding service request.</rdfs:comment>
        <rdfs:label xml:lang="en">Embedding Request</rdfs:label>
    </owl:Class>
    


    <!-- https://dev.qaecy.com/logs#LLMRequest -->


    <owl:Class rdf:about="https://dev.qaecy.com/logs#LLMRequest">
        <rdfs:subClassOf rdf:resource="https://dev.qaecy.com/logs#Process"/>
        <rdfs:comment xml:lang="en">A process representing an LLM API request with token consumption tracking.</rdfs:comment>
        <rdfs:label xml:lang="en">LLM Request</rdfs:label>
    </owl:Class>
    


    <!-- https://dev.qaecy.com/logs#Process -->


    <owl:Class rdf:about="https://dev.qaecy.com/logs#Process">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <owl:disjointWith rdf:resource="https://dev.qaecy.com/logs#Service"/>
        <rdfs:comment xml:lang="en">A process represents an execution of a service within the QAECY logging system.</rdfs:comment>
        <rdfs:label xml:lang="en">Process</rdfs:label>
    </owl:Class>
    


    <!-- https://dev.qaecy.com/logs#Service -->


    <owl:Class rdf:about="https://dev.qaecy.com/logs#Service">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment xml:lang="en">A service or microservice that executes processes (e.g., enrichers-bim-tiles, gemini_light).</rdfs:comment>
        <rdfs:label xml:lang="en">Service</rdfs:label>
    </owl:Class>
    


    <!-- https://dev.qaecy.com/ont#FileLocation -->


    <owl:Class rdf:about="https://dev.qaecy.com/ont#FileLocation"/>
</rdf:RDF>



