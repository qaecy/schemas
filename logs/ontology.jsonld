  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#BIMEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A BIM entity is a special kind of entity mention. It's an intangible (zone) or tangible (element) part of a BIM model."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BIM Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#EntityMention"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#CADLayoutFragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This special fragment constitutes a CAD layout. It should be specified with a selector (qcy:CADLayoutSelector) relative to its parent fragment and the extracted layout's location should be specified."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CAD Layout Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Fragment"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#CADLayoutSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A CAD layout selector specifies the name of a layout in a CAD file. It should be used to connect a qcy:FileContent object representing a CAD file with a qcy:Fragment representing the layout. The value is the name of the layout as specified in the CAD file and corresponds to the block parameter used when extracting an image of the CAD layout using QCAD."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CAD Layout Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#CADViewportFragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This special fragment constitutes a CAD viewport. It should be specified with a selector (qcy:CADViewportSelector) relative to its parent fragment and the extracted viewport's location should be specified."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CAD Viewport Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Fragment"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#CADViewportSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A CAD viewport selector specifies the location of a viewport in a CAD layout. It should be used to connect a qcy:FileContent object representing a CAD layout with a qcy:Fragment representing the viewport. The value is the XYWH coordinates of the viewport within the cartesian coordinate system of the CAD layout (Y axis pointing upwards) normalised to mm. The value corresponds to the window parameter (-w) that is fed to QCAD when extracting an image of the CAD layout and is always."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CAD Viewport Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#CanonicalEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "These are standardized representations of named entities that are the output of an enrichment step in the QAECY pipelines. The entity resolution should include relevant contextual information to distinguish between unique named entities. For example, there can be a ground floor in two buildings but they are not the same concept."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Canonical Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#EntityReference"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://dev.qaecy.com/ont#EntityMention"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#Category",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Abstract class for specific categories that each hold enumerations used for specification of information objects and entity references. It is recommended to use SKOS to establish more context between the Category entities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Category"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://dev.qaecy.com/ont#EntityReference"
  }, {
    "@id" : "https://dev.qaecy.com/ont#FileLocation"
  }, {
    "@id" : "https://dev.qaecy.com/ont#InformationObject"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Property"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#ContentCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Category derived from the content of the file"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Content Category"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Category"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#CoordinateTranslator",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A coordinate translator specifies the parameters needed to translate coordinates from one coordinate system to another. This is used to connect a qcy:Fragment representing a CAD layout with a qcy:Fragment representing an image of that layout, to enable translation of the viewport coordinates in the CAD layout to XYWH coordinates in the image. The value is formatted as an SVG transformation matrix (eg. matrix(56.69, 0, 0, -56.69, 110.07, 257.10))"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Coordinate Translator"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#DocumentPageFragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This special fragment constitutes a page in a paginated document."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Document Page Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Fragment"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#EntityCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Category that specifies the categories of an entity reference"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Entity Category"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Category"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#EntityMention",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An entity mention is an occurrence of a specific entity within a qcy:InformationObject. Each occurrence is unique, meaning that two mentions of \"Albert Einstein\" in the same information object are considered two distinct entity mentions. Entity mentions can describe mentionings of persons, organizations, locations, dates, and other proper nouns."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Entity Mention"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#EntityReference"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#EntityReference",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This abstract class captures reference points for all features of interest in a project, such as a building element, a zone, a person, or material. These references can be either explicit or potential occurrences of the entity. This class should not be assigned directly; instead, use the sub-class qcy:EntityMention for potential occurrences of an entity and qcy:CanonicalEntity for a formalized entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Entity Reference"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://dev.qaecy.com/ont#FileLocation"
  }, {
    "@id" : "https://dev.qaecy.com/ont#InformationObject"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Property"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#FileContent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A file content object represents the full content of a qcy:File. It is uniquely identified by its content, meaning that any modification, even a single character change, results in a new file content object. This ensures that each file content object is immutable and uniquely identifiable. Additionally, a single file content object can be referenced by multiple qcy:File instances, which may be stored in different locations, either locally or in the cloud."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "File Content"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#InformationObject"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#FileLocation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A file location is a digital representation of an information object that is stored on a hard drive, either locally or in the cloud."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "File Location"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://dev.qaecy.com/ont#InformationObject"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Property"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#Fragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A fragment is a subset of a qcy:FileContent object. Each fragment can have sub-fragments in any arbitrary depth (see qcy:containsFragment). For example, a page is a fragment of a document and a text paragraph, image, and table can all be sub-fragments of that page."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#InformationObject"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#IDSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The value specifies an identifier within a structured document, such as an XML or JSON file. For BIM models use one of the more specific ID selectors for the specific kind of ID. The ID Selector is typically used to identify the location of a qcy:EntityMention by its unique ID."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ID Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#IFCExpressIDSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The value of an IFC Express ID Selector specifies the ExpressId of the object within the IFC document. Beware that this ID is only unique in context of that single serailization of the model and is likely to change in future versions of the model."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "IFC Express ID Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#iriPattern" : [ {
    "@value" : "<objectUUID>_expressID"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#IFCGlobalIDSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The value of an IFC Global ID Selector specifies the GlobalId of the object within the IFC document."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "IFC Global ID Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#iriPattern" : [ {
    "@value" : "<objectUUID>_globalID"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#ImageFragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This special fragment constitutes an image. It should be specified with a selector (qcy:XYWHSelector) relative to its parent fragment and the extracted image's location should be specified."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Image Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Fragment"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#InformationObject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An information object is an abstract class that captures all information found in project files. It can either be the full content of the file (see qcy:FileContent) or a subset (see qcy:Fragment). This abstract class should not be defined explicitly, so instead use one of the more specific sub-classes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Information Object"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://dev.qaecy.com/ont#Property"
  }, {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#MimeCategory",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Category derived from the mimetype of the file content"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Mime Category"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Category"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#PageSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A page selector specifies a particular page within a document. This special selector always always connects a qcy:FileContent object with a qcy:DocumentPage. The value is the page number starting from 1."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Page Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#Property",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Any quantitative or qualitative property of an entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Property"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#ProviderType",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Category that specifies the type of provider"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Provider Type"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Category"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#Selector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A selector specifies where in a qcy:InformationObject a qcy:EntityMention occurs. For example from/to what index in a text paragraph, what XYWH bounding box on a page or what GlobalId in an IFC file."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#TableFragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This special fragment constitutes a table with rows and columns. It should specified with a selector (qcy:XYWHSelector) relative to its parent fragment and the qcy:tableGrid should be specified."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Table Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Fragment"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#TextDirectiveSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/conformsTo" : [ {
    "@id" : "https://wicg.github.io/scroll-to-text-fragment/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A text directive selector specifies a range within a text using the syntax \\\"#:~:text=[prefix-,]start[,end][,-suffix]\\\". For example, \\\"#:~:text=example,fragment\\\" would indicate a range from the first occurrence of \\\"example\\\" to the next occurrence of \\\"fragment\\\". This is used to identify the exact location of a qcy:EntityMention within a text fragment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Text Directive Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#TextFragment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This special fragment constitutes a text extraction. It can be the full text of a page a paragraph, footer, header or the like. Except for the former case, it should specified with a selector (qcy:XYWHSelector) to describe it's location relative to its parent fragment. It should also specify a qcy:textRaw and optionally a qcy:textFormatted."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Text Fragment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Fragment"
  } ],
  "https://dev.qaecy.com/ont#iriPattern" : [ {
    "@language" : "en",
    "@value" : "<parentUUID><selectorUUID>"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#TextIndexSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A text index selector specifies a range within a text using start and end separated by a comma (\\\"start,end\\\"). For example \\\"6,11\\\" on the text string \\\"Hello World\\\" would specify the subset \\\"World\\\". This is similar to string slicing in Python and is used to identify the exact location of a qcy:EntityMention within a text fragment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Text Index Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#TimeRangeSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/conformsTo" : [ {
    "@id" : "http://www.w3.org/TR/media-frags/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The value specifies the time range formatted in accordance with http://www.w3.org/TR/media-frags/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Time Range Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
}, {
  "@id" : "https://dev.qaecy.com/ont#XYWHSelector",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/conformsTo" : [ {
    "@id" : "http://www.w3.org/TR/media-frags/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The value specifies the bounding box formatted as an xywh box (http://www.w3.org/TR/media-frags/) either in absolute pixels or relative to the information object. The XYWH Selector is used to identify the location of a qcy:EntityMention or qcy:InformationObject within a visual document."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "XYWH Selector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://dev.qaecy.com/ont#Selector"
  } ],
  "https://dev.qaecy.com/ont#iriPattern" : [ {
    "@value" : "<objectUUID><xywhString>"
  } ],
  "https://dev.qaecy.com/ont#visibleForAgent" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "false"
  } ]
