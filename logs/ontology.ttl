@prefix : <https://dev.qaecy.com/logs#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://dev.qaecy.com/logs#> .

<https://dev.qaecy.com/logs#> rdf:type owl:Ontology ;
                               <http://purl.org/dc/terms/creator> "Christian Frausing" ,
                                                                  "Mads Holten Rasmussen" ,
                                                                  "Manos Argyris" ;
                               <http://purl.org/dc/terms/description> "This document describes log specific terms to be used with the Cue processors and the QAECY Ontology." ;
                               <http://purl.org/dc/terms/modified> "2026-03-26T10:02:36Z"^^xsd:dateTime ;
                               <http://purl.org/dc/terms/title> "QAECY Logging Ontology"@en ;
                               <http://purl.org/vocab/vann/preferredNamespacePrefix> "qcy-l" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/ns/prov#generated
<http://www.w3.org/ns/prov#generated> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#used
<http://www.w3.org/ns/prov#used> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasAssociatedWith
<http://www.w3.org/ns/prov#wasAssociatedWith> rdf:type owl:ObjectProperty .


###  https://dev.qaecy.com/logs#consumed
:consumed rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://www.w3.org/ns/prov#used> ;
          rdfs:domain :Process ;
          rdfs:range :Process ;
          rdfs:comment "Sub-processes or external processes consumed by this process."@en ;
          rdfs:label "consumed"@en .


###  https://dev.qaecy.com/logs#executedBy
:executedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Service ;
            rdfs:range :Process ;
            rdfs:label "executed by"@en .


###  https://dev.qaecy.com/logs#hasService
:hasService rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasAssociatedWith> ;
            owl:inverseOf :executedBy ;
            rdfs:domain :Process ;
            rdfs:range :Service ;
            rdfs:comment "The service that executed this process."@en ;
            rdfs:label "has service"@en .


###  https://dev.qaecy.com/logs#hasSource
:hasSource rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <http://www.w3.org/ns/prov#used> ;
           rdfs:domain :Process ;
           rdfs:range <https://dev.qaecy.com/ont#FileLocation> ;
           rdfs:comment "Source file location used by this process."@en ;
           rdfs:label "has source"@en .


###  https://dev.qaecy.com/logs#hasTarget
:hasTarget rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <http://www.w3.org/ns/prov#generated> ;
           rdfs:domain :Process ;
           rdfs:range <https://dev.qaecy.com/ont#FileLocation> ;
           rdfs:comment "Target file location generated by this process."@en ;
           rdfs:label "has target"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/ns/prov#endedAtTime
<http://www.w3.org/ns/prov#endedAtTime> rdf:type owl:DatatypeProperty .


###  http://www.w3.org/ns/prov#startedAtTime
<http://www.w3.org/ns/prov#startedAtTime> rdf:type owl:DatatypeProperty .


###  https://dev.qaecy.com/logs#consumedTokensIn
:consumedTokensIn rdf:type owl:DatatypeProperty ;
                  rdfs:domain :LLMRequest ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Input tokens consumed by LLM request."@en ;
                  rdfs:label "tokens in"@en .


###  https://dev.qaecy.com/logs#consumedTokensOut
:consumedTokensOut rdf:type owl:DatatypeProperty ;
                   rdfs:domain :LLMRequest ;
                   rdfs:range xsd:integer ;
                   rdfs:comment "Output tokens consumed by LLM request."@en ;
                   rdfs:label "tokens out"@en .


###  https://dev.qaecy.com/logs#duration
:duration rdf:type owl:DatatypeProperty ;
          rdfs:domain :Process ;
          rdfs:range xsd:string ;
          rdfs:comment "Human-readable duration string (e.g., '17.1 s')."@en ;
          rdfs:label "duration"@en .


###  https://dev.qaecy.com/logs#endTime
:endTime rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf <http://www.w3.org/ns/prov#endedAtTime> ;
         rdfs:domain :Process ;
         rdfs:range xsd:dateTime ;
         rdfs:comment "Timestamp when the process ended."@en ;
         rdfs:label "end time"@en .


###  https://dev.qaecy.com/logs#message
:message rdf:type owl:DatatypeProperty ;
         rdfs:domain owl:Thing ;
         rdfs:range xsd:string ;
         rdfs:comment "A message such as an error or informational message."@en ;
         rdfs:label "message"@en .


###  https://dev.qaecy.com/logs#startTime
:startTime rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf <http://www.w3.org/ns/prov#startedAtTime> ;
           rdfs:domain :Process ;
           rdfs:range xsd:dateTime ;
           rdfs:comment "Timestamp when the process started."@en ;
           rdfs:label "start time"@en .


###  https://dev.qaecy.com/logs#success
:success rdf:type owl:DatatypeProperty ;
         rdfs:domain :Process ;
         rdfs:range xsd:boolean ;
         rdfs:comment "Whether the process completed successfully."@en ;
         rdfs:label "success"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
<http://www.w3.org/ns/prov#Agent> rdf:type owl:Class .


###  https://dev.qaecy.com/logs#EmbeddingRequest
:EmbeddingRequest rdf:type owl:Class ;
                  rdfs:subClassOf :Process ;
                  rdfs:comment "A process representing an embedding service request."@en ;
                  rdfs:label "Embedding Request"@en .


###  https://dev.qaecy.com/logs#LLMRequest
:LLMRequest rdf:type owl:Class ;
            rdfs:subClassOf :Process ;
            rdfs:comment "A process representing an LLM API request with token consumption tracking."@en ;
            rdfs:label "LLM Request"@en .


###  https://dev.qaecy.com/logs#Process
:Process rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
         owl:disjointWith :Service ;
         rdfs:comment "A process represents an execution of a service within the QAECY logging system."@en ;
         rdfs:label "Process"@en .


###  https://dev.qaecy.com/logs#Service
:Service rdf:type owl:Class ;
         rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ;
         rdfs:comment "A service or microservice that executes processes (e.g., enrichers-bim-tiles, gemini_light)."@en ;
         rdfs:label "Service"@en .


###  https://dev.qaecy.com/ont#FileLocation
<https://dev.qaecy.com/ont#FileLocation> rdf:type owl:Class .


